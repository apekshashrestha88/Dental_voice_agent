# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Get these from: Twilio Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Get these from: Twilio Console → API Keys & Tokens → Create API Key
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (import it into Vapi Phone Numbers)
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Twilio TwiML App SID (if using Twilio Voice SDK)
TWILIO_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Staff numbers ────────────────────────────────────────────────────────────
# The number calls get transferred to during escalation
SUPPORT_PHONE_NUMBER=+977xxxxxxxxxx
BACKUP_PHONE_NUMBER=+977xxxxxxxxxx