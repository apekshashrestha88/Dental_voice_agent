# ─── Vapi ────────────────────────────────────────────────────────────────────
# Get this from: Vapi Dashboard → Settings → API Keys
VAPI_API_KEY=your-vapi-private-key-here

# Get these from: Vapi Dashboard → Assistants and Phone Numbers
ASSISTANT_ID=your-assistant-id-here
PHONE_NUMBER_ID=your-phone-number-id-here

# Admin dashboard API key — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your-admin-api-key-here